# Copy this file to .streamlit/secrets.toml for LOCAL use,
# OR paste these keys into the Streamlit Community Cloud "Secrets" box when deploying.
# Do NOT commit the real secrets.toml — it is gitignored.

# Required: your Anthropic API key (the patient simulator and evaluator use it).
ANTHROPIC_API_KEY = "sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Recommended for any public deployment: a password that gates the whole app.
# Leave this unset locally to skip the login screen.
APP_PASSWORD = "choose-a-strong-passphrase"
