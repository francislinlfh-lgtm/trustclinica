# Copy this file to .streamlit/secrets.toml for LOCAL use,
# OR paste these keys into the Streamlit Community Cloud "Secrets" box when deploying.
# Do NOT commit the real secrets.toml — it is gitignored.

# ---- Required ----
# Your Anthropic API key (the patient simulator and evaluator use it).
ANTHROPIC_API_KEY = "sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ---- Optional: access control ----
# Leave APP_PASSWORD unset for a public tool (current setup). If you set it,
# the app shows a login screen and only people with the password can enter.
# APP_PASSWORD = "choose-a-strong-passphrase"

# ---- Optional: rate limits (defaults shown; override only if you want) ----
# MAX_SESSIONS_PER_DAY    = "30"   # global cap across all users
# MAX_PER_BROWSER_PER_DAY = "2"    # soft per-browser cap
# MAX_TURNS_PER_SESSION   = "10"   # user messages per encounter

# ---- Optional: Google Sheets pilot logging ----
# SHEET_ID = "the-spreadsheet-id-from-its-url"
#
# [gcp_service_account]
# type = "service_account"
# project_id = "..."
# private_key_id = "..."
# private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# client_email = "...@....iam.gserviceaccount.com"
# client_id = "..."
# auth_uri = "https://accounts.google.com/o/oauth2/auth"
# token_uri = "https://oauth2.googleapis.com/token"
# auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
# client_x509_cert_url = "..."
