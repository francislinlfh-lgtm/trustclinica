# Copy this file to .env and fill in your values.
# .env is listed in .gitignore and should NEVER be committed.

# Your Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=your_api_key_here

# (Optional) Override the Claude model used for patient responses.
# Default is claude-haiku-4-5-20251001 (fast and cheap for the MVP).
# Switch to claude-sonnet-4-6 for more nuanced, higher-quality patient replies.
# CLAUDE_MODEL=claude-sonnet-4-6
